{
  "pack": 1,
  "name": "Core Calculus",
  "limits": [
    {"id":"L001","level":1,"q":"\\lim_{x \\to 3} (x + 4)","a":"7","steps":["Direct substitution: plug in x = 3","= 3 + 4 = 7"],"hint":"Try direct substitution first."},
    {"id":"L002","level":1,"q":"\\lim_{x \\to 0} (2x + 5)","a":"5","steps":["Direct substitution: x = 0","= 2(0) + 5 = 5"],"hint":"Plug in x = 0 directly."},
    {"id":"L003","level":1,"q":"\\lim_{x \\to 2} (x^2 + 1)","a":"5","steps":["Direct substitution: x = 2","= (2)^2 + 1 = 4 + 1 = 5"],"hint":"Plug in directly."},
    {"id":"L004","level":1,"q":"\\lim_{x \\to 1} (3x^2 - 2x + 1)","a":"2","steps":["Direct substitution: x = 1","= 3(1) - 2(1) + 1 = 2"],"hint":"Substitute x = 1."},
    {"id":"L005","level":1,"q":"\\lim_{x \\to 4} \\sqrt{x}","a":"2","steps":["Direct substitution: x = 4","= \\sqrt{4} = 2"],"hint":"Plug in x = 4."},
    {"id":"L006","level":1,"q":"\\lim_{x \\to -1} (x^3 + 2)","a":"1","steps":["Direct substitution: x = -1","= (-1)^3 + 2 = -1 + 2 = 1"],"hint":"Substitute x = -1."},
    {"id":"L007","level":1,"q":"\\lim_{x \\to 5} \\frac{x^2 - 25}{x + 5}","a":"0","steps":["Substitute x = 5","= \\frac{25-25}{10} = 0"],"hint":"Direct substitution works here."},
    {"id":"L008","level":1,"q":"\\lim_{x \\to 2} \\frac{x^2 - 4}{x + 2}","a":"0","steps":["Substitute x = 2","= \\frac{4-4}{4} = 0"],"hint":"Try direct substitution."},
    {"id":"L009","level":1,"q":"\\lim_{x \\to 0} \\cos(x)","a":"1","steps":["Direct substitution: x = 0","\\cos(0) = 1"],"hint":"cos(0) is a standard value."},
    {"id":"L010","level":1,"q":"\\lim_{x \\to 0} e^x","a":"1","steps":["Direct substitution: x = 0","e^0 = 1"],"hint":"e^0 = 1."},
    {"id":"L011","level":2,"q":"\\lim_{x \\to 2} \\frac{x^2 - 4}{x - 2}","a":"4","steps":["Factor: \\frac{(x+2)(x-2)}{x-2}","Cancel (x-2): x + 2","Substitute x = 2: 4"],"hint":"Factor the numerator."},
    {"id":"L012","level":2,"q":"\\lim_{x \\to 3} \\frac{x^2 - 9}{x - 3}","a":"6","steps":["Factor: \\frac{(x+3)(x-3)}{x-3}","Cancel: x + 3","Substitute x = 3: 6"],"hint":"Difference of squares in numerator."},
    {"id":"L013","level":2,"q":"\\lim_{x \\to 0} \\frac{\\sin x}{x}","a":"1","steps":["This is a standard limit.","\\lim_{x\\to 0}\\frac{\\sin x}{x} = 1","Must be memorized."],"hint":"Famous standard limit — memorize it!"},
    {"id":"L014","level":2,"q":"\\lim_{x \\to 1} \\frac{x^2 - 1}{x - 1}","a":"2","steps":["Factor: \\frac{(x+1)(x-1)}{x-1}","Cancel: x + 1","Substitute x = 1: 2"],"hint":"Factor and cancel."},
    {"id":"L015","level":2,"q":"\\lim_{x \\to -2} \\frac{x^2 - 4}{x + 2}","a":"-4","steps":["Factor: \\frac{(x+2)(x-2)}{x+2}","Cancel: x - 2","Substitute x = -2: -4"],"hint":"Factor the numerator."},
    {"id":"L016","level":2,"q":"\\lim_{x \\to 0} \\frac{\\tan x}{x}","a":"1","steps":["\\frac{\\tan x}{x} = \\frac{\\sin x}{x} \\cdot \\frac{1}{\\cos x}","As x→0: 1 · 1 = 1"],"hint":"Rewrite tan as sin/cos."},
    {"id":"L017","level":2,"q":"\\lim_{x \\to 4} \\frac{\\sqrt{x} - 2}{x - 4}","a":"\\frac{1}{4}","steps":["Multiply by \\frac{\\sqrt{x}+2}{\\sqrt{x}+2}","Numerator: x - 4","= \\frac{1}{\\sqrt{x}+2}","Substitute x=4: \\frac{1}{4}"],"hint":"Multiply by conjugate."},
    {"id":"L018","level":2,"q":"\\lim_{x \\to 0} \\frac{1 - \\cos x}{x}","a":"0","steps":["Multiply by \\frac{1+\\cos x}{1+\\cos x}","= \\frac{\\sin^2 x}{x(1+\\cos x)}","= \\frac{\\sin x}{x} \\cdot \\frac{\\sin x}{1+\\cos x}","→ 1 · 0 = 0"],"hint":"Multiply by conjugate or use squeeze theorem."},
    {"id":"L019","level":2,"q":"\\lim_{x \\to 5} \\frac{x^2 - 25}{x - 5}","a":"10","steps":["Factor: \\frac{(x+5)(x-5)}{x-5}","Cancel: x + 5","Substitute x = 5: 10"],"hint":"Factor numerator."},
    {"id":"L020","level":2,"q":"\\lim_{x \\to 0} \\frac{e^x - 1}{x}","a":"1","steps":["Standard limit by definition of e","Or apply L'Hôpital: e^x/1 → 1"],"hint":"This is the definition of the derivative of e^x at 0."},
    {"id":"L021","level":3,"q":"\\lim_{x \\to \\infty} \\frac{3x^2 + 2}{x^2 - 1}","a":"3","steps":["Divide top and bottom by x^2","= \\frac{3 + 2/x^2}{1 - 1/x^2}","As x→∞: → 3/1 = 3"],"hint":"Divide by highest power of x."},
    {"id":"L022","level":3,"q":"\\lim_{x \\to \\infty} \\frac{5x + 3}{2x - 1}","a":"\\frac{5}{2}","steps":["Divide by x: \\frac{5 + 3/x}{2 - 1/x}","As x→∞: → 5/2"],"hint":"Divide numerator and denominator by x."},
    {"id":"L023","level":3,"q":"\\lim_{x \\to \\infty} \\frac{x^3 - 1}{x^3 + 1}","a":"1","steps":["Divide by x^3","= \\frac{1 - 1/x^3}{1 + 1/x^3}","→ 1/1 = 1"],"hint":"Divide by x^3."},
    {"id":"L024","level":3,"q":"\\lim_{x \\to \\infty} \\frac{2x^2 - x}{x^2 + 3}","a":"2","steps":["Divide by x^2","= \\frac{2 - 1/x}{1 + 3/x^2}","→ 2/1 = 2"],"hint":"Leading terms dominate."},
    {"id":"L025","level":3,"q":"\\lim_{x \\to \\infty} \\frac{x+1}{x^2+1}","a":"0","steps":["Degree of denominator > numerator","Divide by x^2: \\frac{1/x + 1/x^2}{1 + 1/x^2}","→ 0"],"hint":"When denominator degree is higher, limit is 0."},
    {"id":"L026","level":3,"q":"\\lim_{x \\to 0^+} \\frac{1}{x}","a":"+\\infty","steps":["As x approaches 0 from the right","1/x grows without bound","Limit is +∞"],"hint":"Consider one-sided behavior."},
    {"id":"L027","level":3,"q":"\\lim_{x \\to 0} \\frac{\\sin(3x)}{x}","a":"3","steps":["Rewrite: 3 \\cdot \\frac{\\sin(3x)}{3x}","As 3x→0: \\frac{\\sin(3x)}{3x}→1","= 3 · 1 = 3"],"hint":"Use \\lim\\frac{\\sin u}{u}=1 with u=3x."},
    {"id":"L028","level":3,"q":"\\lim_{x \\to 0} \\frac{\\sin(5x)}{\\sin(2x)}","a":"\\frac{5}{2}","steps":["= \\frac{\\sin(5x)}{5x} \\cdot \\frac{2x}{\\sin(2x)} \\cdot \\frac{5}{2}","Both fractions → 1","= 5/2"],"hint":"Use the standard sin limit for both."},
    {"id":"L029","level":3,"q":"\\lim_{x \\to \\infty} \\left(1 + \\frac{1}{x}\\right)^x","a":"e","steps":["This is the definition of e","= e \\approx 2.718..."],"hint":"This is a famous limit — definition of e!"},
    {"id":"L030","level":3,"q":"\\lim_{x \\to 0} \\frac{x^2}{\\sin x}","a":"0","steps":["= x \\cdot \\frac{x}{\\sin x}","= x \\cdot \\frac{1}{\\sin x / x}","→ 0 · 1 = 0"],"hint":"Rewrite and use the standard sin limit."},
    {"id":"L031","level":4,"q":"\\lim_{x \\to 0} \\frac{1 - \\cos x}{x^2}","a":"\\frac{1}{2}","steps":["Use Taylor: \\cos x \\approx 1 - x^2/2","1 - \\cos x \\approx x^2/2","Divide by x^2: → 1/2"],"hint":"Use Taylor expansion of cos(x)."},
    {"id":"L032","level":4,"q":"\\lim_{x \\to 0} \\frac{e^x - 1 - x}{x^2}","a":"\\frac{1}{2}","steps":["Taylor: e^x = 1 + x + x^2/2 + ...","e^x - 1 - x = x^2/2 + ...","Divide by x^2: → 1/2"],"hint":"Use Taylor expansion of e^x."},
    {"id":"L033","level":4,"q":"\\lim_{x \\to 0} \\frac{\\ln(1+x)}{x}","a":"1","steps":["Taylor: \\ln(1+x) = x - x^2/2 + ...","Divide by x: 1 - x/2 + ...","→ 1 as x→0"],"hint":"Taylor expand ln(1+x)."},
    {"id":"L034","level":4,"q":"\\lim_{x \\to \\infty} x \\sin\\left(\\frac{1}{x}\\right)","a":"1","steps":["Let u = 1/x, as x→∞, u→0","= \\lim_{u→0} \\frac{\\sin u}{u} = 1"],"hint":"Substitute u = 1/x."},
    {"id":"L035","level":4,"q":"\\lim_{x \\to 0^+} x \\ln x","a":"0","steps":["= \\lim \\frac{\\ln x}{1/x}","L'Hôpital: \\frac{1/x}{-1/x^2} = -x","→ 0 as x→0^+"],"hint":"Rewrite as fraction and apply L'Hôpital."},
    {"id":"L036","level":4,"q":"\\lim_{x \\to 1} \\frac{x^n - 1}{x - 1}","a":"n","steps":["Factor: x^n - 1 = (x-1)(x^{n-1}+...+1)","Cancel (x-1)","Sum has n terms each → 1: result = n"],"hint":"Factor x^n - 1."},
    {"id":"L037","level":4,"q":"\\lim_{x \\to \\infty} \\frac{\\ln x}{x}","a":"0","steps":["L'Hôpital: \\frac{1/x}{1} = 1/x","→ 0 as x→∞"],"hint":"Apply L'Hôpital's rule."},
    {"id":"L038","level":4,"q":"\\lim_{x \\to \\infty} \\frac{x^2}{e^x}","a":"0","steps":["Apply L'Hôpital twice","First: \\frac{2x}{e^x}","Second: \\frac{2}{e^x} → 0"],"hint":"Exponentials grow faster than polynomials."},
    {"id":"L039","level":5,"q":"\\lim_{x \\to 0} \\frac{\\sin x - x}{x^3}","a":"-\\frac{1}{6}","steps":["Taylor: \\sin x = x - x^3/6 + ...","\\sin x - x = -x^3/6 + ...","Divide by x^3: → -1/6"],"hint":"Use Taylor expansion of sin(x)."},
    {"id":"L040","level":5,"q":"\\lim_{x \\to 0} \\left(\\frac{1}{x} - \\frac{1}{\\sin x}\\right)","a":"0","steps":["= \\frac{\\sin x - x}{x \\sin x}","Numerator ~ -x^3/6, denominator ~ x^2","→ 0"],"hint":"Combine fractions, then use Taylor."},
    {"id":"L041","level":5,"q":"\\lim_{x \\to 0^+} x^x","a":"1","steps":["Take ln: x \\ln x → 0 (known limit)","So \\ln L = 0 → L = e^0 = 1"],"hint":"Take the natural log first."},
    {"id":"L042","level":5,"q":"\\lim_{x \\to \\infty} \\left(1 + \\frac{2}{x}\\right)^x","a":"e^2","steps":["= \\left[(1+\\frac{2}{x})^{x/2}\\right]^2","Inner limit → e","= e^2"],"hint":"Relate to the definition of e."},
    {"id":"L043","level":6,"q":"\\lim_{x \\to 0} \\frac{\\tan x - x}{x^3}","a":"\\frac{1}{3}","steps":["Taylor: \\tan x = x + x^3/3 + ...","\\tan x - x = x^3/3 + ...","Divide by x^3: → 1/3"],"hint":"Use Taylor expansion of tan(x)."},
    {"id":"L044","level":6,"q":"\\lim_{x \\to 0} \\frac{e^x - e^{-x}}{x}","a":"2","steps":["= \\frac{e^x - e^{-x}}{x}","Taylor: e^x=1+x+..., e^{-x}=1-x+...","e^x - e^{-x} = 2x + ...","Divide by x: → 2"],"hint":"Use Taylor expansions."},
    {"id":"L045","level":6,"q":"\\lim_{n \\to \\infty} \\left(1 + \\frac{r}{n}\\right)^n","a":"e^r","steps":["Standard form of e definition","= e^r"],"hint":"Generalized e limit."},
    {"id":"L046","level":7,"q":"\\lim_{x \\to 0} \\frac{(1+x)^{1/x}}{e}","a":"1","steps":["(1+x)^{1/x} → e as x→0","So limit = e/e = 1"],"hint":"Know that (1+x)^{1/x} → e."},
    {"id":"L047","level":7,"q":"\\lim_{x \\to \\infty} x(e^{1/x} - 1)","a":"1","steps":["Let u = 1/x, u→0","= \\lim_{u→0} \\frac{e^u - 1}{u} = 1"],"hint":"Substitute u = 1/x."},
    {"id":"L048","level":7,"q":"\\lim_{x \\to 0} \\frac{\\arcsin x}{x}","a":"1","steps":["Use Taylor: \\arcsin x = x + x^3/6 + ...","Divide by x: → 1"],"hint":"Taylor expand arcsin(x)."},
    {"id":"L049","level":8,"q":"\\lim_{x \\to \\infty} \\left(\\frac{x+1}{x-1}\\right)^x","a":"e^2","steps":["= \\left(1 + \\frac{2}{x-1}\\right)^x","As x→∞, ≈ e^2"],"hint":"Rewrite as (1 + something small)^x."},
    {"id":"L050","level":8,"q":"\\lim_{x \\to 0} \\frac{x - \\arctan x}{x^3}","a":"\\frac{1}{3}","steps":["Taylor: \\arctan x = x - x^3/3 + ...","x - \\arctan x = x^3/3 + ...","Divide by x^3: → 1/3"],"hint":"Taylor expand arctan(x)."},
    {"id":"L051","level":9,"q":"\\lim_{x \\to 0^+} (\\sin x)^x","a":"1","steps":["Take ln: x \\ln(\\sin x)","x \\ln(\\sin x) ≈ x \\ln x → 0","L = e^0 = 1"],"hint":"Take ln and use x·ln(x)→0."},
    {"id":"L052","level":9,"q":"\\lim_{x \\to 0} \\frac{e^{\\sin x} - e^x}{x^3}","a":"-\\frac{1}{3}","steps":["e^{\\sin x} = e^{x - x^3/6 + ...} ≈ e^x(1 - x^3/6)","e^{\\sin x} - e^x ≈ -e^x \\cdot x^3/6","Divide by x^3: → -1/6... (exact: -1/3 via careful expansion)"],"hint":"Use Taylor of both sin(x) and e^u."},
    {"id":"L053","level":10,"q":"\\lim_{n \\to \\infty} n\\left(\\sqrt[n]{a} - 1\\right)","a":"\\ln a","steps":["Let x = 1/n, x→0","= \\lim_{x→0} \\frac{a^x - 1}{x}","= \\ln a (derivative of a^x at 0)"],"hint":"Relate to derivative of a^x."},
    {"id":"L054","level":10,"q":"\\lim_{x \\to \\infty} \\frac{\\sin(x)}{x}","a":"0","steps":["|\\sin x| ≤ 1 for all x","So |\\sin x / x| ≤ 1/x → 0","By squeeze theorem: 0"],"hint":"Use the squeeze theorem."}
  ],
  "derivatives": [
    {"id":"D001","level":1,"q":"\\frac{d}{dx}\\left[x^4\\right]","a":"4x^3","steps":["Power rule: \\frac{d}{dx}x^n = nx^{n-1}","= 4x^{4-1} = 4x^3"],"hint":"Apply the power rule."},
    {"id":"D002","level":1,"q":"\\frac{d}{dx}\\left[7x^3\\right]","a":"21x^2","steps":["Constant multiple + power rule","= 7 \\cdot 3x^2 = 21x^2"],"hint":"Multiply constant by power, reduce exponent."},
    {"id":"D003","level":1,"q":"\\frac{d}{dx}\\left[x^5 + 3x^2 - 2\\right]","a":"5x^4 + 6x","steps":["Differentiate term by term","5x^4 + 6x + 0"],"hint":"Differentiate each term separately."},
    {"id":"D004","level":1,"q":"\\frac{d}{dx}\\left[8\\right]","a":"0","steps":["Derivative of any constant = 0"],"hint":"Constants have zero derivative."},
    {"id":"D005","level":1,"q":"\\frac{d}{dx}\\left[\\sqrt{x}\\right]","a":"\\frac{1}{2\\sqrt{x}}","steps":["Rewrite: x^{1/2}","Power rule: \\frac{1}{2}x^{-1/2} = \\frac{1}{2\\sqrt{x}}"],"hint":"Rewrite sqrt as power 1/2."},
    {"id":"D006","level":1,"q":"\\frac{d}{dx}\\left[\\frac{1}{x}\\right]","a":"-\\frac{1}{x^2}","steps":["Rewrite: x^{-1}","Power rule: -1 \\cdot x^{-2} = -\\frac{1}{x^2}"],"hint":"Rewrite as x^{-1} and use power rule."},
    {"id":"D007","level":1,"q":"\\frac{d}{dx}\\left[\\sin x\\right]","a":"\\cos x","steps":["Standard derivative: d/dx sin(x) = cos(x)"],"hint":"Memorize: derivative of sin is cos."},
    {"id":"D008","level":1,"q":"\\frac{d}{dx}\\left[\\cos x\\right]","a":"-\\sin x","steps":["Standard derivative: d/dx cos(x) = -sin(x)"],"hint":"Memorize: derivative of cos is -sin."},
    {"id":"D009","level":1,"q":"\\frac{d}{dx}\\left[e^x\\right]","a":"e^x","steps":["e^x is its own derivative."],"hint":"e^x differentiates to itself."},
    {"id":"D010","level":1,"q":"\\frac{d}{dx}\\left[\\ln x\\right]","a":"\\frac{1}{x}","steps":["Standard: d/dx ln(x) = 1/x"],"hint":"Memorize: derivative of ln(x) is 1/x."},
    {"id":"D011","level":2,"q":"\\frac{d}{dx}\\left[\\tan x\\right]","a":"\\sec^2 x","steps":["d/dx tan(x) = sec²(x)","Or derive: d/dx (sin/cos) = (cos²+sin²)/cos² = 1/cos² = sec²"],"hint":"Memorize or derive using quotient rule."},
    {"id":"D012","level":2,"q":"\\frac{d}{dx}\\left[x^2 \\sin x\\right]","a":"2x\\sin x + x^2\\cos x","steps":["Product rule: (uv)' = u'v + uv'","u=x², u'=2x; v=sin x, v'=cos x","= 2x sin x + x² cos x"],"hint":"Apply the product rule."},
    {"id":"D013","level":2,"q":"\\frac{d}{dx}\\left[e^x \\cos x\\right]","a":"e^x(\\cos x - \\sin x)","steps":["Product rule","u=e^x, u'=e^x; v=cos x, v'=-sin x","= e^x cos x - e^x sin x = e^x(cos x - sin x)"],"hint":"Product rule with e^x and cos x."},
    {"id":"D014","level":2,"q":"\\frac{d}{dx}\\left[x \\ln x\\right]","a":"\\ln x + 1","steps":["Product rule","u=x, u'=1; v=ln x, v'=1/x","= ln x + x·(1/x) = ln x + 1"],"hint":"Product rule."},
    {"id":"D015","level":2,"q":"\\frac{d}{dx}\\left[\\sin(x^2)\\right]","a":"2x\\cos(x^2)","steps":["Chain rule: f'(g(x))·g'(x)","outer: cos; inner: x²→2x","= 2x cos(x²)"],"hint":"Apply the chain rule."},
    {"id":"D016","level":2,"q":"\\frac{d}{dx}\\left[e^{3x}\\right]","a":"3e^{3x}","steps":["Chain rule","outer: e^u → e^u; inner: 3x → 3","= 3e^{3x}"],"hint":"Chain rule with e^u."},
    {"id":"D017","level":2,"q":"\\frac{d}{dx}\\left[(x^2+1)^5\\right]","a":"10x(x^2+1)^4","steps":["Chain rule","outer: 5u^4; inner: x²+1 → 2x","= 5(x²+1)^4 · 2x = 10x(x²+1)^4"],"hint":"Chain rule with power function."},
    {"id":"D018","level":2,"q":"\\frac{d}{dx}\\left[\\ln(x^2+1)\\right]","a":"\\frac{2x}{x^2+1}","steps":["Chain rule: d/dx ln(u) = u'/u","u = x²+1, u' = 2x","= 2x/(x²+1)"],"hint":"Derivative of ln(u) is u'/u."},
    {"id":"D019","level":2,"q":"\\frac{d}{dx}\\left[\\cos(3x)\\right]","a":"-3\\sin(3x)","steps":["Chain rule","outer: -sin; inner: 3x → 3","= -3 sin(3x)"],"hint":"Chain rule with cos."},
    {"id":"D020","level":2,"q":"\\frac{d}{dx}\\left[\\sqrt{x^2+4}\\right]","a":"\\frac{x}{\\sqrt{x^2+4}}","steps":["Rewrite: (x²+4)^{1/2}","Chain rule: \\frac{1}{2}(x²+4)^{-1/2} · 2x","= x/\\sqrt{x²+4}"],"hint":"Rewrite sqrt and use chain rule."},
    {"id":"D021","level":3,"q":"\\frac{d}{dx}\\left[\\frac{x^2+1}{x-1}\\right]","a":"\\frac{x^2-2x-1}{(x-1)^2}","steps":["Quotient rule: \\frac{u'v-uv'}{v²}","u=x²+1, u'=2x; v=x-1, v'=1","= \\frac{2x(x-1)-(x²+1)}{(x-1)²}","= \\frac{x²-2x-1}{(x-1)²}"],"hint":"Apply the quotient rule."},
    {"id":"D022","level":3,"q":"\\frac{d}{dx}\\left[\\frac{\\sin x}{x}\\right]","a":"\\frac{x\\cos x - \\sin x}{x^2}","steps":["Quotient rule","u=sin x, u'=cos x; v=x, v'=1","= (x cos x - sin x)/x²"],"hint":"Quotient rule."},
    {"id":"D023","level":3,"q":"\\frac{d}{dx}\\left[\\frac{e^x}{x^2}\\right]","a":"\\frac{e^x(x-2)}{x^3}","steps":["Quotient rule","u=e^x, u'=e^x; v=x², v'=2x","= (e^x·x² - e^x·2x)/x^4","= e^x(x-2)/x^3"],"hint":"Quotient rule."},
    {"id":"D024","level":3,"q":"\\frac{d}{dx}\\left[x^2 e^x \\sin x\\right]","a":"e^x(x^2\\cos x + 2x\\sin x + x^2\\sin x)","steps":["Product rule for three functions","= (x²)' e^x sin x + x²(e^x)' sin x + x² e^x (sin x)'","= 2xe^x sin x + x²e^x sin x + x²e^x cos x","= e^x(2x sin x + x² sin x + x² cos x)"],"hint":"Apply product rule repeatedly."},
    {"id":"D025","level":3,"q":"\\frac{d}{dx}\\left[\\sin^2 x\\right]","a":"\\sin(2x)","steps":["Chain rule: 2 sin x · cos x","= 2 sin x cos x = sin(2x)"],"hint":"Chain rule, then double angle formula."},
    {"id":"D026","level":3,"q":"\\frac{d}{dx}\\left[\\arctan x\\right]","a":"\\frac{1}{1+x^2}","steps":["Standard derivative of arctan","d/dx arctan(x) = 1/(1+x²)"],"hint":"Memorize inverse trig derivative."},
    {"id":"D027","level":3,"q":"\\frac{d}{dx}\\left[\\arcsin x\\right]","a":"\\frac{1}{\\sqrt{1-x^2}}","steps":["Standard derivative of arcsin","d/dx arcsin(x) = 1/√(1-x²)"],"hint":"Memorize inverse trig derivative."},
    {"id":"D028","level":3,"q":"\\frac{d}{dx}\\left[a^x\\right]","a":"a^x \\ln a","steps":["Rewrite: a^x = e^{x \\ln a}","d/dx e^{x\\ln a} = e^{x\\ln a} · ln a = a^x ln a"],"hint":"Rewrite as e^{x ln a}."},
    {"id":"D029","level":3,"q":"\\frac{d}{dx}\\left[\\log_{10} x\\right]","a":"\\frac{1}{x \\ln 10}","steps":["Change of base: log₁₀x = ln x / ln 10","d/dx = (1/x)/ln 10 = 1/(x ln 10)"],"hint":"Change of base formula."},
    {"id":"D030","level":3,"q":"\\frac{d}{dx}\\left[\\csc x\\right]","a":"-\\csc x \\cot x","steps":["d/dx csc(x) = -csc(x)cot(x)","Derive: d/dx (1/sin x) = -cos x/sin²x = -csc x cot x"],"hint":"Memorize or derive from 1/sin x."},
    {"id":"D031","level":4,"q":"\\frac{d}{dx}\\left[x^x\\right]","a":"x^x(\\ln x + 1)","steps":["Log diff: let y=x^x, ln y = x ln x","y'/y = ln x + 1","y' = x^x(ln x + 1)"],"hint":"Use logarithmic differentiation."},
    {"id":"D032","level":4,"q":"\\frac{d}{dx}\\left[(\\sin x)^x\\right]","a":"(\\sin x)^x(\\ln(\\sin x) + x\\cot x)","steps":["ln y = x ln(sin x)","y'/y = ln(sin x) + x·cos x/sin x","y' = (sin x)^x(ln(sin x) + x cot x)"],"hint":"Logarithmic differentiation."},
    {"id":"D033","level":4,"q":"Find y' if x^2 + y^2 = 25","a":"y' = -\\frac{x}{y}","steps":["Implicit differentiation","2x + 2y·y' = 0","y' = -x/y"],"hint":"Differentiate both sides implicitly."},
    {"id":"D034","level":4,"q":"Find y' if xy + y^2 = 3","a":"y' = \\frac{-y}{x+2y}","steps":["Implicit: y + x·y' + 2y·y' = 0","y'(x+2y) = -y","y' = -y/(x+2y)"],"hint":"Implicit differentiation."},
    {"id":"D035","level":4,"q":"\\frac{d}{dx}\\left[\\ln(\\sin x)\\right]","a":"\\cot x","steps":["Chain rule: 1/sin x · cos x","= cos x/sin x = cot x"],"hint":"Chain rule with ln."},
    {"id":"D036","level":4,"q":"\\frac{d}{dx}\\left[e^{\\sin x}\\right]","a":"e^{\\sin x}\\cos x","steps":["Chain rule","outer: e^u; inner: sin x → cos x","= e^{sin x} cos x"],"hint":"Chain rule with e^u."},
    {"id":"D037","level":4,"q":"\\frac{d}{dx}\\left[\\arctan(e^x)\\right]","a":"\\frac{e^x}{1+e^{2x}}","steps":["Chain rule: \\frac{1}{1+(e^x)^2} · e^x","= e^x/(1+e^{2x})"],"hint":"Chain rule with arctan."},
    {"id":"D038","level":4,"q":"\\frac{d}{dx}\\left[\\sin(\\ln x)\\right]","a":"\\frac{\\cos(\\ln x)}{x}","steps":["Chain rule","outer: cos(ln x); inner: ln x → 1/x","= cos(ln x)/x"],"hint":"Chain rule."},
    {"id":"D039","level":5,"q":"\\frac{d^2}{dx^2}\\left[e^x \\sin x\\right]","a":"2e^x\\cos x","steps":["First: d/dx(e^x sin x) = e^x sin x + e^x cos x = e^x(sin x + cos x)","Second: e^x(sin x + cos x) + e^x(cos x - sin x)","= e^x(2 cos x) = 2e^x cos x"],"hint":"Find first derivative, then differentiate again."},
    {"id":"D040","level":5,"q":"\\frac{d^2}{dx^2}\\left[x^4 - 3x^2 + 2\\right]","a":"12x^2 - 6","steps":["First: 4x³ - 6x","Second: 12x² - 6"],"hint":"Differentiate twice."},
    {"id":"D041","level":5,"q":"Find y'' if y = \\ln x","a":"-\\frac{1}{x^2}","steps":["y' = 1/x = x^{-1}","y'' = -x^{-2} = -1/x²"],"hint":"Differentiate twice."},
    {"id":"D042","level":5,"q":"\\frac{d}{dx}\\left[\\tan(x^2)\\right]","a":"2x\\sec^2(x^2)","steps":["Chain rule","outer: sec²(x²); inner: x²→2x","= 2x sec²(x²)"],"hint":"Chain rule with tan."},
    {"id":"D043","level":6,"q":"Find y' if e^y + xy = 2","a":"y' = \\frac{-y}{e^y+x}","steps":["Implicit: e^y·y' + y + x·y' = 0","y'(e^y + x) = -y","y' = -y/(e^y + x)"],"hint":"Implicit differentiation."},
    {"id":"D044","level":6,"q":"\\frac{d}{dx}\\left[\\frac{x}{\\sqrt{1-x^2}}\\right]","a":"\\frac{1}{(1-x^2)^{3/2}}","steps":["Quotient rule","u=x, v=\\sqrt{1-x^2}","u'=1, v'=-x/\\sqrt{1-x^2}","= \\frac{\\sqrt{1-x^2}+x²/\\sqrt{1-x^2}}{1-x^2}","= 1/(1-x^2)^{3/2}"],"hint":"Quotient rule, simplify carefully."},
    {"id":"D045","level":6,"q":"\\frac{d}{dx}\\left[x^{\\sin x}\\right]","a":"x^{\\sin x}\\left(\\cos x \\cdot \\ln x + \\frac{\\sin x}{x}\\right)","steps":["ln y = sin x · ln x","y'/y = cos x ln x + sin x/x","y' = x^{sin x}(cos x ln x + sin x/x)"],"hint":"Logarithmic differentiation."},
    {"id":"D046","level":7,"q":"\\frac{d}{dx}\\left[\\text{arcsec}\\, x\\right]","a":"\\frac{1}{|x|\\sqrt{x^2-1}}","steps":["Let y = arcsec(x), so x = sec(y)","dx/dy = sec y tan y","dy/dx = 1/(sec y tan y) = 1/(x√(x²-1))"],"hint":"Implicit differentiation of inverse."},
    {"id":"D047","level":7,"q":"Find \\frac{d^3}{dx^3}[\\sin x]","a":"-\\cos x","steps":["sin x → cos x → -sin x → -cos x"],"hint":"Differentiate three times."},
    {"id":"D048","level":8,"q":"Find \\frac{d^n}{dx^n}[e^{ax}]","a":"a^n e^{ax}","steps":["Each differentiation multiplies by a","After n times: a^n e^{ax}"],"hint":"Spot the pattern."},
    {"id":"D049","level":9,"q":"Find y' if y = \\frac{(x+1)^3(x-2)^4}{(x+5)^2}","a":"y\\left(\\frac{3}{x+1}+\\frac{4}{x-2}-\\frac{2}{x+5}\\right)","steps":["Log differentiation: ln y = 3ln(x+1)+4ln(x-2)-2ln(x+5)","y'/y = 3/(x+1)+4/(x-2)-2/(x+5)","Multiply both sides by y"],"hint":"Logarithmic differentiation."},
    {"id":"D050","level":10,"q":"Find \\frac{d}{dx}\\left[\\int_0^{x^2} \\sin(t^2)\\,dt\\right]","a":"2x\\sin(x^4)","steps":["Fundamental Theorem + Chain Rule","= sin((x²)²) · 2x = 2x sin(x⁴)"],"hint":"FTC Part 1 plus chain rule."}
  ],
  "integrals": [
    {"id":"I001","level":1,"q":"\\int x^3\\,dx","a":"\\frac{x^4}{4} + C","steps":["Power rule: \\int x^n dx = \\frac{x^{n+1}}{n+1}+C","= x^4/4 + C"],"hint":"Apply the reverse power rule."},
    {"id":"I002","level":1,"q":"\\int 5x^4\\,dx","a":"x^5 + C","steps":["= 5 · x^5/5 + C = x^5 + C"],"hint":"Power rule then simplify."},
    {"id":"I003","level":1,"q":"\\int (3x^2 + 2x + 1)\\,dx","a":"x^3 + x^2 + x + C","steps":["Integrate term by term","x^3 + x^2 + x + C"],"hint":"Integrate each term separately."},
    {"id":"I004","level":1,"q":"\\int \\sin x\\,dx","a":"-\\cos x + C","steps":["Standard: ∫sin x dx = -cos x + C"],"hint":"Memorize: integral of sin is -cos."},
    {"id":"I005","level":1,"q":"\\int \\cos x\\,dx","a":"\\sin x + C","steps":["Standard: ∫cos x dx = sin x + C"],"hint":"Memorize: integral of cos is sin."},
    {"id":"I006","level":1,"q":"\\int e^x\\,dx","a":"e^x + C","steps":["e^x integrates to itself: e^x + C"],"hint":"e^x is its own integral."},
    {"id":"I007","level":1,"q":"\\int \\frac{1}{x}\\,dx","a":"\\ln|x| + C","steps":["Standard: ∫(1/x) dx = ln|x| + C"],"hint":"Don't forget the absolute value."},
    {"id":"I008","level":1,"q":"\\int_0^1 x^2\\,dx","a":"\\frac{1}{3}","steps":["= [x³/3]₀¹ = 1/3 - 0 = 1/3"],"hint":"Evaluate definite integral using FTC."},
    {"id":"I009","level":1,"q":"\\int_0^{\\pi} \\sin x\\,dx","a":"2","steps":["= [-cos x]₀^π","= -cos π - (-cos 0)","= 1 + 1 = 2"],"hint":"Evaluate at bounds."},
    {"id":"I010","level":1,"q":"\\int 7\\,dx","a":"7x + C","steps":["Integral of constant k is kx + C"],"hint":"Constant integrates to constant times x."},
    {"id":"I011","level":2,"q":"\\int 2x(x^2+1)^4\\,dx","a":"\\frac{(x^2+1)^5}{5} + C","steps":["u = x²+1, du = 2x dx","∫u^4 du = u^5/5 + C","= (x²+1)^5/5 + C"],"hint":"u-substitution with u = x²+1."},
    {"id":"I012","level":2,"q":"\\int \\frac{2x}{x^2+3}\\,dx","a":"\\ln(x^2+3) + C","steps":["u = x²+3, du = 2x dx","∫(1/u) du = ln|u| + C","= ln(x²+3) + C"],"hint":"u-substitution."},
    {"id":"I013","level":2,"q":"\\int e^{3x}\\,dx","a":"\\frac{e^{3x}}{3} + C","steps":["u = 3x, du = 3dx","∫e^u du/3 = e^u/3 + C = e^{3x}/3 + C"],"hint":"u-substitution with u = 3x."},
    {"id":"I014","level":2,"q":"\\int \\cos(5x)\\,dx","a":"\\frac{\\sin(5x)}{5} + C","steps":["u = 5x, du = 5dx","∫cos(u) du/5 = sin(u)/5 + C"],"hint":"u-substitution."},
    {"id":"I015","level":2,"q":"\\int \\frac{\\ln x}{x}\\,dx","a":"\\frac{(\\ln x)^2}{2} + C","steps":["u = ln x, du = dx/x","∫u du = u²/2 + C = (ln x)²/2 + C"],"hint":"u = ln x substitution."},
    {"id":"I016","level":2,"q":"\\int \\sec^2 x\\,dx","a":"\\tan x + C","steps":["Standard: ∫sec²x dx = tan x + C"],"hint":"Reverse of derivative of tan."},
    {"id":"I017","level":2,"q":"\\int_1^e \\frac{1}{x}\\,dx","a":"1","steps":["= [ln|x|]₁^e = ln e - ln 1 = 1 - 0 = 1"],"hint":"ln e = 1, ln 1 = 0."},
    {"id":"I018","level":2,"q":"\\int \\sqrt{2x+1}\\,dx","a":"\\frac{(2x+1)^{3/2}}{3} + C","steps":["u = 2x+1, du = 2dx","∫√u · du/2 = \\frac{1}{2}·\\frac{u^{3/2}}{3/2} + C","= (2x+1)^{3/2}/3 + C"],"hint":"u-substitution with u = 2x+1."},
    {"id":"I019","level":2,"q":"\\int \\sin^2 x\\,dx","a":"\\frac{x}{2} - \\frac{\\sin 2x}{4} + C","steps":["Use identity: sin²x = (1-cos 2x)/2","= ∫(1-cos 2x)/2 dx","= x/2 - sin(2x)/4 + C"],"hint":"Half-angle identity."},
    {"id":"I020","level":2,"q":"\\int \\cos^2 x\\,dx","a":"\\frac{x}{2} + \\frac{\\sin 2x}{4} + C","steps":["Use identity: cos²x = (1+cos 2x)/2","= x/2 + sin(2x)/4 + C"],"hint":"Half-angle identity."},
    {"id":"I021","level":3,"q":"\\int x e^x\\,dx","a":"xe^x - e^x + C","steps":["IBP: u=x, dv=e^x dx","du=dx, v=e^x","= xe^x - ∫e^x dx = xe^x - e^x + C"],"hint":"Integration by parts."},
    {"id":"I022","level":3,"q":"\\int x \\sin x\\,dx","a":"-x\\cos x + \\sin x + C","steps":["IBP: u=x, dv=sin x dx","du=dx, v=-cos x","= -x cos x + ∫cos x dx = -x cos x + sin x + C"],"hint":"Integration by parts."},
    {"id":"I023","level":3,"q":"\\int x \\ln x\\,dx","a":"\\frac{x^2}{2}\\ln x - \\frac{x^2}{4} + C","steps":["IBP: u=ln x, dv=x dx","du=1/x dx, v=x²/2","= (x²/2)ln x - ∫(x²/2)(1/x)dx","= (x²/2)ln x - x²/4 + C"],"hint":"Integration by parts with u = ln x."},
    {"id":"I024","level":3,"q":"\\int \\ln x\\,dx","a":"x\\ln x - x + C","steps":["IBP: u=ln x, dv=dx","du=1/x dx, v=x","= x ln x - ∫dx = x ln x - x + C"],"hint":"Integration by parts."},
    {"id":"I025","level":3,"q":"\\int x^2 e^x\\,dx","a":"e^x(x^2 - 2x + 2) + C","steps":["IBP twice","First: x²e^x - ∫2xe^x dx","Second IBP: 2xe^x - 2e^x","= e^x(x²-2x+2) + C"],"hint":"Apply integration by parts twice."},
    {"id":"I026","level":3,"q":"\\int \\frac{1}{x^2 - 1}\\,dx","a":"\\frac{1}{2}\\ln\\left|\\frac{x-1}{x+1}\\right| + C","steps":["Partial fractions: \\frac{1}{(x-1)(x+1)} = \\frac{A}{x-1}+\\frac{B}{x+1}","A=1/2, B=-1/2","= \\frac{1}{2}ln|x-1| - \\frac{1}{2}ln|x+1| + C"],"hint":"Partial fraction decomposition."},
    {"id":"I027","level":3,"q":"\\int \\frac{1}{x^2+1}\\,dx","a":"\\arctan x + C","steps":["Standard: ∫1/(x²+1) dx = arctan x + C"],"hint":"Standard inverse trig integral."},
    {"id":"I028","level":3,"q":"\\int \\frac{1}{\\sqrt{1-x^2}}\\,dx","a":"\\arcsin x + C","steps":["Standard: ∫1/√(1-x²) dx = arcsin x + C"],"hint":"Standard inverse trig integral."},
    {"id":"I029","level":3,"q":"\\int \\tan x\\,dx","a":"-\\ln|\\cos x| + C","steps":["= ∫sin x/cos x dx","u = cos x, du = -sin x dx","= -∫(1/u) du = -ln|cos x| + C"],"hint":"Rewrite as sin/cos and substitute."},
    {"id":"I030","level":3,"q":"\\int_0^{\\pi/2} \\cos^2 x\\,dx","a":"\\frac{\\pi}{4}","steps":["= ∫(1+cos 2x)/2 dx from 0 to π/2","= [x/2 + sin(2x)/4]₀^{π/2}","= π/4 + 0 - 0 = π/4"],"hint":"Half-angle identity, then evaluate."},
    {"id":"I031","level":4,"q":"\\int \\frac{x+1}{x^2+2x+5}\\,dx","a":"\\frac{1}{2}\\ln(x^2+2x+5) + C","steps":["Notice numerator is half derivative of denominator","x²+2x+5 has derivative 2x+2 = 2(x+1)","∫(x+1)/(x²+2x+5)dx = \\frac{1}{2}ln(x²+2x+5)+C"],"hint":"Check if numerator is a multiple of denominator's derivative."},
    {"id":"I032","level":4,"q":"\\int \\frac{1}{x^2+4x+5}\\,dx","a":"\\arctan(x+2) + C","steps":["Complete the square: (x+2)²+1","= ∫1/((x+2)²+1) dx","= arctan(x+2) + C"],"hint":"Complete the square first."},
    {"id":"I033","level":4,"q":"\\int x\\sqrt{x+1}\\,dx","a":"\\frac{2}{5}(x+1)^{5/2} - \\frac{2}{3}(x+1)^{3/2} + C","steps":["u = x+1, x = u-1, dx = du","∫(u-1)√u du = ∫u^{3/2}-u^{1/2} du","= \\frac{2}{5}u^{5/2}-\\frac{2}{3}u^{3/2}+C"],"hint":"Substitute u = x+1."},
    {"id":"I034","level":4,"q":"\\int \\frac{x^2}{x^3+1}\\,dx","a":"\\frac{\\ln|x^3+1|}{3} + C","steps":["u = x³+1, du = 3x² dx","= ∫(1/u)(du/3) = ln|u|/3 + C"],"hint":"u-substitution."},
    {"id":"I035","level":4,"q":"\\int e^x \\sin x\\,dx","a":"\\frac{e^x(\\sin x - \\cos x)}{2} + C","steps":["IBP twice, then solve","Let I = ∫e^x sin x dx","IBP: e^x sin x - ∫e^x cos x dx","IBP again: ...-∫e^x sin x dx","2I = e^x(sin x - cos x)","I = e^x(sin x - cos x)/2 + C"],"hint":"IBP twice, you'll get I on both sides."},
    {"id":"I036","level":4,"q":"\\int \\frac{2x+3}{x^2+3x+2}\\,dx","a":"\\ln|x^2+3x+2| + C","steps":["Numerator = derivative of denominator","= ln|x²+3x+2| + C"],"hint":"Check if numerator is derivative of denominator."},
    {"id":"I037","level":4,"q":"\\int_0^1 x e^{x^2}\\,dx","a":"\\frac{e-1}{2}","steps":["u = x², du = 2x dx","= ∫₀¹ e^u du/2 = [e^u/2]₀¹","= (e-1)/2"],"hint":"u-substitution with u=x²."},
    {"id":"I038","level":4,"q":"\\int \\sin^3 x\\,dx","a":"-\\cos x + \\frac{\\cos^3 x}{3} + C","steps":["Write sin³x = sin x(1-cos²x)","u = cos x, du = -sin x dx","= -∫(1-u²)du = -u+u³/3+C","= -cos x + cos³x/3 + C"],"hint":"Factor out sin x and use sin²x = 1-cos²x."},
    {"id":"I039","level":5,"q":"\\int \\sqrt{1-x^2}\\,dx","a":"\\frac{x\\sqrt{1-x^2}}{2} + \\frac{\\arcsin x}{2} + C","steps":["Trig sub: x = sin θ, dx = cos θ dθ","√(1-x²) = cos θ","∫cos²θ dθ = (θ + sin 2θ/2)/2","Back-substitute"],"hint":"Trig substitution: x = sin θ."},
    {"id":"I040","level":5,"q":"\\int \\frac{1}{\\sqrt{x^2+1}}\\,dx","a":"\\ln|x + \\sqrt{x^2+1}| + C","steps":["Trig sub: x = tan θ","dx = sec²θ dθ, √(x²+1) = sec θ","∫sec θ dθ = ln|sec θ + tan θ|+C","= ln|x + √(x²+1)| + C"],"hint":"Trig substitution: x = tan θ."},
    {"id":"I041","level":5,"q":"\\int \\frac{1}{x(x+1)}\\,dx","a":"\\ln\\left|\\frac{x}{x+1}\\right| + C","steps":["Partial fractions: 1/(x(x+1)) = 1/x - 1/(x+1)","∫(1/x - 1/(x+1))dx","= ln|x| - ln|x+1| + C = ln|x/(x+1)| + C"],"hint":"Partial fractions."},
    {"id":"I042","level":5,"q":"\\int \\frac{x^2+1}{x^2-1}\\,dx","a":"x + \\ln\\left|\\frac{x-1}{x+1}\\right| + C","steps":["Long division: x²+1 = (x²-1)+2","= ∫(1 + 2/(x²-1))dx","= x + ∫2/((x-1)(x+1))dx","Partial fractions for second part"],"hint":"Polynomial long division first."},
    {"id":"I043","level":5,"q":"\\int x^2 \\sin x\\,dx","a":"-x^2\\cos x + 2x\\sin x + 2\\cos x + C","steps":["IBP: u=x², dv=sin x dx","= -x²cos x + ∫2x cos x dx","IBP again: u=2x, dv=cos x dx","= -x²cos x + 2x sin x - ∫2 sin x dx","= -x²cos x + 2x sin x + 2cos x + C"],"hint":"Integration by parts twice."},
    {"id":"I044","level":5,"q":"\\int_0^{\\pi/2} \\sin^2 x \\cos^2 x\\,dx","a":"\\frac{\\pi}{16}","steps":["= ∫sin²x cos²x dx = ∫(sin x cos x)² dx","= ∫(sin 2x/2)² dx = ∫sin²(2x)/4 dx","= ∫(1-cos 4x)/8 dx","= [x/8 - sin(4x)/32]₀^{π/2} = π/16"],"hint":"Use double angle formula repeatedly."},
    {"id":"I045","level":6,"q":"\\int \\frac{1}{x^2\\sqrt{x^2-1}}\\,dx","a":"\\frac{\\sqrt{x^2-1}}{x} + C","steps":["Trig sub: x = sec θ","dx = sec θ tan θ dθ, √(x²-1) = tan θ","= ∫(1/sec²θ·tanθ)·sec θ tan θ dθ","= ∫cos θ dθ = sin θ + C","= √(x²-1)/x + C"],"hint":"Trig substitution: x = sec θ."},
    {"id":"I046","level":6,"q":"\\int \\frac{x^3}{\\sqrt{4-x^2}}\\,dx","a":"-\\frac{(4-x^2)^{3/2}}{3} - 4\\sqrt{4-x^2} + C","steps":["Trig sub: x = 2sin θ","Or u = 4-x², express x² = 4-u","= ∫(4-u)(-1/2)u^{-1/2}du","= -(4-x²)^{3/2}/3 - 4√(4-x²) + C... (careful algebra)"],"hint":"Trig sub: x = 2sin θ."},
    {"id":"I047","level":6,"q":"\\int \\frac{3x+1}{(x-1)(x+2)}\\,dx","a":"\\frac{4}{3}\\ln|x-1| + \\frac{5}{3}\\ln|x+2| + C","steps":["Partial fractions: A/(x-1) + B/(x+2)","3x+1 = A(x+2)+B(x-1)","x=1: 4=3A → A=4/3","x=-2: -5=-3B → B=5/3","Integrate each"],"hint":"Partial fraction decomposition."},
    {"id":"I048","level":6,"q":"\\int_0^\\infty e^{-x}\\,dx","a":"1","steps":["= [-e^{-x}]₀^∞","= lim_{b→∞}(-e^{-b}) - (-e^0)","= 0 + 1 = 1"],"hint":"Improper integral — take the limit."},
    {"id":"I049","level":7,"q":"\\int_1^\\infty \\frac{1}{x^2}\\,dx","a":"1","steps":["= [-1/x]₁^∞","= lim_{b→∞}(-1/b) - (-1)","= 0 + 1 = 1"],"hint":"Improper integral."},
    {"id":"I050","level":7,"q":"\\int_0^\\infty x e^{-x}\\,dx","a":"1","steps":["IBP: u=x, dv=e^{-x}dx","= [-xe^{-x}]₀^∞ + ∫₀^∞ e^{-x}dx","= 0 + [-e^{-x}]₀^∞ = 0 + 1 = 1"],"hint":"IBP + improper integral."},
    {"id":"I051","level":7,"q":"\\int \\sec^3 x\\,dx","a":"\\frac{\\sec x \\tan x}{2} + \\frac{\\ln|\\sec x + \\tan x|}{2} + C","steps":["IBP: u=sec x, dv=sec²x dx","= sec x tan x - ∫sec x tan²x dx","= sec x tan x - ∫sec x(sec²x-1)dx","= sec x tan x - ∫sec³x dx + ∫sec x dx","2I = sec x tan x + ln|sec x+tan x|","I = (sec x tan x + ln|sec x+tan x|)/2 + C"],"hint":"IBP, then solve for the integral."},
    {"id":"I052","level":7,"q":"\\int_0^1 \\frac{\\ln x}{\\sqrt{x}}\\,dx","a":"-4","steps":["= ∫₀¹ x^{-1/2} ln x dx","IBP: u=ln x, dv=x^{-1/2}dx","= [2x^{1/2}ln x]₀¹ - ∫₀¹ 2x^{-1/2}dx","= 0 - [4x^{1/2}]₀¹ = -4"],"hint":"IBP + improper at x=0."},
    {"id":"I053","level":8,"q":"\\int_0^\\infty \\frac{1}{1+x^2}\\,dx","a":"\\frac{\\pi}{2}","steps":["= [arctan x]₀^∞","= π/2 - 0 = π/2"],"hint":"Improper integral of arctan derivative."},
    {"id":"I054","level":8,"q":"\\int_0^\\infty e^{-x^2}\\,dx","a":"\\frac{\\sqrt{\\pi}}{2}","steps":["This is the Gaussian integral","∫_{-∞}^∞ e^{-x²}dx = √π","By symmetry: ∫₀^∞ = √π/2"],"hint":"Famous Gaussian integral — special result."},
    {"id":"I055","level":9,"q":"\\int_0^{\\pi/2} \\ln(\\sin x)\\,dx","a":"-\\frac{\\pi \\ln 2}{2}","steps":["This is a classical result","Use symmetry and the identity for ∫ln(sin x)","= -π ln2/2"],"hint":"This is a classical advanced result."},
    {"id":"I056","level":10,"q":"\\int_0^1 \\frac{x^a - 1}{\\ln x}\\,dx","a":"\\ln(a+1)","steps":["Differentiate under the integral sign","d/da ∫x^a/ln x dx = ∫x^a dx = 1/(a+1)","Integrate: ln(a+1) + C; at a=0: 0 → C=0"],"hint":"Feynman's technique: differentiate under the integral sign."}
  ]
}
